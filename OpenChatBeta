-- FUNÇÃO DE NOTIFICAÇÃO
local function NotificarMensagem(sender, msg)
    StarterGui:SetCore("SendNotification", {
        Title = "Global Chat: " .. sender,
        Text = msg,
        Icon = "rbxassetid://18940312887",
        Duration = 5
    })
end

-- CONEXÃO WEBSOCKET
local function StartNetwork()
    local socket
    local wsUrl = "wss://free.blr2.piesocket.com/v3/1?api_key=nJwrvMLQ39lJLpcxH88UbwiV08uXKrqSV7zvC1Z4&notify_self=1"
    
    local success, _ = pcall(function()
        socket = WebSocket.connect(wsUrl)
    end)

    if socket then
        socket.OnMessage:Connect(function(msg)
            local ok, data = pcall(function() return HttpService:JSONDecode(msg) end)
            if ok and data.message then
                -- Adicionar ao quadro
                local label = Instance.new("TextLabel")
                label.Size = UDim2.new(1, 0, 0, 30)
                label.BackgroundTransparency = 1
                label.RichText = true
                label.Font = Enum.Font.SourceSansBold
                label.TextColor3 = Color3.fromRGB(255, 255, 255)
                label.TextSize = 22
                label.TextXAlignment = Enum.TextXAlignment.Left
                label.Text = string.format("<font color='#ffffff'>[%s]:</font> %s", data.nickname or data.username, data.message)
                label.AutomaticSize = Enum.AutomaticSize.Y
                label.TextWrapped = true
                label.Parent = G2L.ChatHistory
                
                -- Notificar se não for eu
                if data.username ~= Player.Name then
                    NotificarMensagem(data.nickname or data.username, data.message)
                end

                -- Balão na cabeça
                local TargetPlayer = Players:FindFirstChild(data.username)
                if TargetPlayer and TargetPlayer.Character and TargetPlayer.Character:FindFirstChild("Head") then
                    ChatService:Chat(TargetPlayer.Character.Head, data.message, Enum.ChatColor.White)
                end
                
                G2L.ChatHistory.CanvasPosition = Vector2.new(0, G2L.Layout.AbsoluteContentSize.Y)
            end
        end)

        local function enviar()
            if G2L.Input.Text ~= "" then
                socket:Send(HttpService:JSONEncode({
                    username = Player.Name, 
                    nickname = Player.DisplayName, 
                    message = G2L.Input.Text
                }))
                G2L.Input.Text = ""
            end
        end

        G2L.SendBtn.MouseButton1Click:Connect(enviar)
        G2L.Input.FocusLost:Connect(function(enter) if enter then enviar() end end)
    end
end

-- ARRASTAR
local function MakeDraggable(obj)
    local dragging, dragInput, dragStart, startPos
    obj.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = obj.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            obj.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

