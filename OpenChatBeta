-- LÓGICA DO WEBSOCKET COM SINCRONIZAÇÃO DE BALÕES
local function StartNetwork()
    local socket
    local key = "eLudeCBiiTiQSr6DWJPMPfpZK9B6ghEu90ZbJwzm"

    local success, _ = pcall(function()
        socket = WebSocket.connect("wss://free.blr2.piesocket.com/v3/1?api_key="..key.."&notify_self=1")
    end)

    if socket then
        socket.OnMessage:Connect(function(msg)
            local data = HttpService:JSONDecode(msg)
            
            -- 1. CRIAR MENSAGEM NA INTERFACE (TAMANHO 19)
            local label = Instance.new("TextLabel")
            label.Size = UDim2.new(1, 0, 0, 25)
            label.BackgroundTransparency = 1
            label.RichText = true
            label.Font = Enum.Font.SourceSansBold
            label.TextColor3 = Color3.fromRGB(255, 255, 255)
            label.TextSize = 19 -- TAMANHO SOLICITADO
            label.TextXAlignment = Enum.TextXAlignment.Left
            label.Text = string.format("<font color='#ffffff'>[%s]:</font> %s", data.nickname or data.username, data.message)
            label.AutomaticSize = Enum.AutomaticSize.Y
            label.TextWrapped = true
            label.ZIndex = 7
            label.Parent = G2L.ChatHistory
            G2L.ChatHistory.CanvasPosition = Vector2.new(0, G2L.Layout.AbsoluteContentSize.Y)

            -- 2. SINCRONIZAÇÃO DE BALÃO (BUBBLE SYNC)
            -- Procura se o dono da mensagem está no mesmo servidor
            local TargetPlayer = Players:FindFirstChild(data.username)
            if TargetPlayer and TargetPlayer.Character and TargetPlayer.Character:FindFirstChild("Head") then
                ChatService:Chat(TargetPlayer.Character.Head, data.message, Enum.ChatColor.White)
            end
        end)

        local function enviar()
            local msgText = G2L.Input.Text
            if msgText ~= "" then
                -- Envia para o servidor global (os balões serão gerados pelo OnMessage acima)
                socket:Send(HttpService:JSONEncode({
                    username = Player.Name, 
                    nickname = Player.DisplayName, 
                    message = msgText
                }))
                G2L.Input.Text = ""
            end
        end

        G2L.SendBtn.MouseButton1Click:Connect(enviar)
        G2L.Input.FocusLost:Connect(function(enter) if enter then enviar() end end)
    end
end

task.spawn(StartNetwork)

